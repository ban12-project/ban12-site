{
  "name": "web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node --env-file-if-exists=.env --import tsx lib/db/migrate.ts && next build",
    "start": "next start",
    "lint": "biome check --write",
    "type-check": "next typegen && tsc --noEmit",
    "analyze": "ANALYZE=true next build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env --import tsx lib/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:check": "drizzle-kit check",
    "db:up": "drizzle-kit up"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "catalog:",
    "@better-auth/passkey": "catalog:",
    "@google/genai": "catalog:",
    "@gsap/react": "catalog:",
    "@hookform/resolvers": "catalog:",
    "@neondatabase/serverless": "^1.1.0",
    "@next/third-parties": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@repo/i18n": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "@upstash/redis": "catalog:",
    "better-auth": "catalog:",
    "coordtransform": "^2.1.2",
    "drizzle-orm": "catalog:",
    "fast-deep-equal": "^3.1.3",
    "glsl-random": "^0.0.5",
    "gsap": "catalog:",
    "inngest": "^4.4.0",
    "lucide-react": "catalog:",
    "mapbox-gl": "^3.23.1",
    "next": "catalog:",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "recharts": "catalog:",
    "server-only": "catalog:",
    "sonner": "catalog:",
    "three": "^0.184.0",
    "tunnel-rat": "^0.1.2",
    "usehooks-ts": "catalog:",
    "vaul": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "catalog:",
    "@repo/biome-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/three": "^0.184.1",
    "babel-plugin-react-compiler": "catalog:",
    "drizzle-kit": "catalog:",
    "file-loader": "^6.2.0",
    "glslify": "^7.1.1",
    "glslify-loader": "^2.0.0",
    "postcss": "catalog:",
    "raw-loader": "^4.0.2",
    "tsx": "^4.22.0",
    "typescript": "catalog:",
    "url-loader": "^4.1.1"
  }
}
